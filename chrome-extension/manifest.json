{
  "manifest_version": 3,
  "name": "GX-Sentinel: Ambient Mentor",
  "version": "2.0",
  "description": "Context-aware financial mentor acting across all platforms.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["dist/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "GX-Sentinel Status"
  }
}